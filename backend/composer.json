{
  "name": "cardzey/cv-analyzer-backend",
  "description": "Backend API for CV Analyzer platform",
  "type": "project",
  "require": {
    "php": "^8.0",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "./"
    },
    "classmap": [
      "controllers/",
      "models/",
      "middleware/",
      "config/",
      "utils/"
    ]
  },
  "scripts": {
    "post-install-cmd": [
      "echo 'Backend dependencies installed'"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
